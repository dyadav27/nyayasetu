# ─────────────────────────────────────────────────────────────────────────────
# Nyaya-Setu .env — copy to .env and fill values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# ── GPU: Force RTX 4050, disable Intel iGPU ──────────────────────────────────
# On OMEN laptops: Intel = device 0, NVIDIA RTX = device 1
# gpu_utils.py auto-detects this, but you can override:
# CUDA_VISIBLE_DEVICES=1          # uncomment only if gpu_utils picks wrong device
# CUDA_DEVICE_ORDER=PCI_BUS_ID   # uncomment only if needed

# ── LLM: Ollama (local GPU — FREE, no API key) ────────────────────────────────
# Install: https://ollama.ai/download
# Then run: ollama pull llama3
# Ollama automatically uses RTX 4050 — no config needed
OLLAMA_MODEL=llama3

# ── Bhashini (ASR + NMT + TTS — FREE) ────────────────────────────────────────
# Sign up: https://bhashini.gov.in/ulca/search-model-and-details
# Go to: My Profile → Generate API Key
BHASHINI_USER_ID=your_user_id_here
BHASHINI_API_KEY=your_api_key_here

# ── Twilio WhatsApp Sandbox (FREE trial) ─────────────────────────────────────
# Sign up: https://twilio.com → Console → Messaging → WhatsApp Sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── OpenAI Whisper fallback (OPTIONAL — only if Bhashini ASR fails) ──────────
OPENAI_API_KEY=sk-your_key_here_optional

# ── ngrok URL (local dev only — for Twilio media delivery) ───────────────────
NGROK_URL=https://xxxx-xx-xx-xxx-xx.ngrok-free.app

# ── Paths ─────────────────────────────────────────────────────────────────────
CHROMA_DIR=data/chromadb
PDF_DIR=data/statutes
